import requests
from telegram import Update
from telegram.ext import Application, CommandHandler, ContextTypes, MessageHandler, filters

TG_TOKEN = ""
API_KEY = ""
URL = "https://openrouter.ai/api/v1/chat/completions"
MODEL = "openrouter/free"
MAX_TG_MESSAGE_LENGTH = 4000
MAX_HISTORY_MESSAGES = 10

chat_history = {}
state = {}

SYSTEM_PROMPT = (
    "Ты — интеллектуальный ИИ-ассистент, специализирующийся на анализе моральных "
    "выборов и этических дилемм. Твоя задача — помогать пользователю рассматривать "
    "сложные ситуации, где нет однозначно правильного решения. Анализируй последствия "
    "каждого выбора, учитывай эмоции, ценности, интересы всех участников и разные "
    "философские подходы к морали. Не навязывай собственное мнение и не говори "
    "пользователю, какое решение является правильным. Вместо этого помогай глубже "
    "понять ситуацию через вопросы для размышления, сравнение вариантов и объективный "
    "анализ. Каждый твой ответ должен быть написан на двух языках: сначала полностью "
    "на русском языке, затем полностью продублирован на английском языке. Сохраняй "
    "одинаковый смысл, структуру и детали в обеих версиях."
)


def reset_dialog(chat_id):
    chat_history.pop(chat_id, None)
    state.pop(chat_id, None)


def ask_ai(chat_id, message):
    history = chat_history.setdefault(chat_id, [])
    history.append({"role": "user", "content": message})

    try:
        response = requests.post(
            URL,
            headers={
                "Authorization": f"Bearer {API_KEY}",
                "Content-Type": "application/json",
            },
            json={
                "model": MODEL,
                "messages": [
                    {"role": "system", "content": SYSTEM_PROMPT},
                    *history,
                ],
            },
            timeout=60,
        )
        data = response.json()
    except requests.RequestException as e:
        history.pop()
        return f"Ошибка соединения: {e}"

    if response.status_code != 200 or "choices" not in data or len(data["choices"]) == 0:
        history.pop()
        error_msg = data.get("error", {})
        if isinstance(error_msg, dict):
            msg = error_msg.get("message", "ошибка")
        else:
            msg = str(error_msg) if error_msg else "ошибка"
        return f"Ошибка: {msg}"

    try:
        answer = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        history.pop()
        return "Ошибка при разборе ответа от ИИ"

    if not answer:
        history.pop()
        return "Пустой ответ от ИИ"

    history.append({"role": "assistant", "content": answer})
    if len(history) > MAX_HISTORY_MESSAGES:
        chat_history[chat_id] = history[-MAX_HISTORY_MESSAGES:]

    return answer


async def send_long_message(update: Update, text: str) -> None:
    if not text:
        return

    for i in range(0, len(text), MAX_TG_MESSAGE_LENGTH):
        chunk = text[i : i + MAX_TG_MESSAGE_LENGTH]
        await update.message.reply_text(chunk)


async def start_command(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    reset_dialog(update.effective_chat.id)
    await update.message.reply_text(
        "Привет! Я бот для разбора моральных дилемм. "
        "Напиши свою ситуацию, а /reset — сбросить диалог."
    )


async def reset_command(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    reset_dialog(update.effective_chat.id)
    await update.message.reply_text("Диалог сброшен.")


async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    text = update.message.text.strip()
    if not text:
        return

    chat_id = update.effective_chat.id

    await update.message.chat.send_action(action="typing")
    ai_response = ask_ai(chat_id, text)
    await send_long_message(update, ai_response)


def main() -> None:
    application = Application.builder().token(TG_TOKEN).build()

    application.add_handler(CommandHandler("start", start_command))
    application.add_handler(CommandHandler("reset", reset_command))
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

    print("Бот запущен. Ожидаю сообщения...")
    application.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == "__main__":
    main()
