import random
import requests
import vk_api
from vk_api.longpoll import VkBotEventType, VkLongPoll

VK_TOKEN = ""
GROUP_ID = 240410715
API_KEY = ""
URL = "https://openrouter.ai/api/v1/chat/completions"
MODEL = "openrouter/free"

chat_history = {}
state = {}

SYSTEM_PROMPT = (
    "Ты — интеллектуальный ИИ-ассистент, специализирующийся на анализе моральных "
    "выборов и этических дилемм. Твоя задача — помогать пользователю рассматривать "
    "сложные ситуации, где нет однозначно правильного решения. Анализируй последствия "
    "каждого выбора, учитывай эмоции, ценности, интересы всех участников и разные "
    "философские подходы к морали. Не навязывай собственное мнение и не говори "
    "пользователю, какое решение является правильным. Вместо этого помогай глубже "
    "понять ситуацию через вопросы для размышления, сравнение вариантов и объективный "
    "анализ. Каждый твой ответ должен быть написан на двух языках: сначала полностью "
    "на русском языке, затем полностью продублирован на английском языке. Сохраняй "
    "одинаковый смысл, структуру и детали в обеих версиях."
)

vk_session = vk_api.VkApi(token=VK_TOKEN)
vk = vk_session.get_api()
longpoll = VkLongPoll(vk_session, GROUP_ID)

MAX_VK_MESSAGE_LENGTH = 4000
MAX_HISTORY_MESSAGES = 10


def send_message(user_id, text):
    if not text:
        return

    for i in range(0, len(text), MAX_VK_MESSAGE_LENGTH):
        chunk = text[i : i + MAX_VK_MESSAGE_LENGTH]
        vk.messages.send(
            user_id=user_id,
            message=chunk,
            random_id=random.randint(1, 2**31 - 1),
        )


def reset_dialog(user_id):
    chat_history.pop(user_id, None)
    state.pop(user_id, None)


def ask_ai(user_id, message):
    history = chat_history.setdefault(user_id, [])
    history.append({"role": "user", "content": message})

    messages = [{"role": "system", "content": SYSTEM_PROMPT}] + history[-MAX_HISTORY_MESSAGES:]

    try:
        response = requests.post(
            URL,
            headers={
                "Authorization": f"Bearer {API_KEY}",
                "Content-Type": "application/json",
            },
            json={
                "model": MODEL,
                "messages": messages,
            },
            timeout=60,
        )
        data = response.json()
    except requests.RequestException as e:
        history.pop()
        return f"Ошибка соединения: {e}"

    if response.status_code != 200 or "choices" not in data:
        history.pop()
        error_msg = data.get("error", {})
        if isinstance(error_msg, dict):
            msg = error_msg.get("message", "ошибка")
        else:
            msg = str(error_msg) if error_msg else "ошибка"
        return f"Ошибка: {msg}"

    try:
        answer = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        history.pop()
        return "Ошибка при разборе ответа от ИИ"

    if not answer:
        history.pop()
        return "Пустой ответ от ИИ"

    history.append({"role": "assistant", "content": answer})
    if len(history) > MAX_HISTORY_MESSAGES:
        chat_history[user_id] = history[-MAX_HISTORY_MESSAGES:]

    return answer


print("Бот запущен. Ожидаю сообщения...")

for event in longpoll.listen():
    if event.type != VkBotEventType.MESSAGE_NEW:
        continue

    user_id = event.obj.message["from_id"]
    text = event.obj.message["text"].strip()

    print(f"Новое сообщение от {user_id}: {text}")

    if text.lower() in ("/reset", "сброс"):
        reset_dialog(user_id)
        send_message(user_id, "Диалог сброшен. Можете начать заново.")
        continue

    answer = ask_ai(user_id, text)
    send_message(user_id, answer)





